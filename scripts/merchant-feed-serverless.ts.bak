/**
 * Dynamic Google Merchant Center XML Product Feed (Serverless Function)
 *
 * FALLBACK: The primary feed is now a static file at /merchant-feed.xml
 * generated at build time. This serverless function serves as a dynamic
 * alternative if the static file becomes stale.
 *
 * URL: https://luxemia.shop/api/merchant-feed
 *
 * If you get 403 errors on this endpoint, use the static feed instead:
 * https://luxemia.shop/merchant-feed.xml
 */

const SHOPIFY_STOREFRONT_URL = 'https://lovable-project-zlh0w.myshopify.com/api/2025-07/graphql.json';
const SHOPIFY_STOREFRONT_TOKEN = 'c98d10d5abd95e6a8d6ddbed223ef4b4';
const SITE_URL = 'https://luxemia.shop';

const ALL_PRODUCTS_QUERY = `
  query GetAllProducts($first: Int!, $after: String) {
    products(first: $first, after: $after, sortKey: CREATED_AT, reverse: true) {
      pageInfo { hasNextPage endCursor }
      edges {
        node {
          id title description handle vendor productType tags availableForSale
          priceRange { minVariantPrice { amount currencyCode } }
          compareAtPriceRange { maxVariantPrice { amount currencyCode } }
          images(first: 5) { edges { node { url altText } } }
          variants(first: 20) { edges { node { id title sku price { amount currencyCode } compareAtPrice { amount currencyCode } availableForSale selectedOptions { name value } } } }
          options { name values }
        }
      }
    }
  }
`;

function escapeXml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&apos;'); }

function forceJpeg(url) {
  if (!url) return url;
  if (url.includes('cdn.shopify.com') || url.includes('myshopify.com')) { const c=url.replace(/[&?]format=\w+/g,''); return `${c}${c.includes('?')?'&':'?'}format=jpg&width=1200`; }
  if (url.includes('kesimg.b-cdn.net')) { const c=url.replace(/[&?]format=\w+/g,''); return `${c}${c.includes('?')?'&':'?'}format=jpg`; }
  if (!url.match(/\.(jpg|jpeg|png|gif)(\?|$)/i) && !url.includes('format=')) { return `${url}${url.includes('?')?'&':'?'}format=jpg`; }
  return url;
}

function getGoogleProductCategory(pt, t) {
  pt=(pt||'').toLowerCase(); t=(t||'').toLowerCase();
  if (pt.includes('men')||t.includes('sherwani')||t.includes('kurta pajama')||t.includes('groom wear')) { if(t.includes('sherwani'))return'2195'; if(t.includes('kurta'))return'2197'; return'2104'; }
  if (pt.includes('lehenga')||t.includes('lehenga')) return '2271';
  if (pt.includes('saree')||t.includes('saree')) return '5424';
  if (pt.includes('necklace')||t.includes('necklace')) return '193';
  if (pt.includes('earring')||t.includes('earring')) return '194';
  if (pt.includes('bangle')||pt.includes('bracelet')||t.includes('bangle')) return '200';
  if (pt.includes('jewel')||t.includes('jewel')) return '188';
  if (pt.includes('suit')||pt.includes('anarkali')||pt.includes('sharara')||pt.includes('palazzo')||pt.includes('salwar')) return '2271';
  if (pt.includes('indo western')||pt.includes('indo-western')) return '2271';
  return '1604';
}

function getGender(pt,t) { pt=(pt||'').toLowerCase(); t=(t||'').toLowerCase(); return (pt.includes('men')||t.includes('sherwani')||t.includes('kurta pajama')||t.includes('groom'))?'male':'female'; }

function getSizes(p) {
  const o=p.options?.find(o=>/size|bust size|chest size/i.test(o.name));
  if(o&&o.values.length>0) return o.values;
  const pt=(p.productType||'').toLowerCase();
  return /lehenga|saree|suit|salwar|anarkali|men|sherwani|kurta|dress|indo western|sharara|palazzo/.test(pt)?['S','M','L','XL','XXL']:[];
}

function shippingXml(cur) {
  return ['US','CA','GB','AE','AU'].map(c=>`
    <g:shipping><g:country>${c}</g:country><g:service>DHL Express Free over $300</g:service><g:price>0.00 ${cur}</g:price><g:min_handling_time>3</g:min_handling_time><g:max_handling_time>5</g:max_handling_time><g:min_transit_time>3</g:min_transit_time><g:max_transit_time>5</g:max_transit_time></g:shipping>
    <g:shipping><g:country>${c}</g:country><g:service>Standard</g:service><g:price>25.00 ${cur}</g:price><g:min_handling_time>3</g:min_handling_time><g:max_handling_time>5</g:max_handling_time><g:min_transit_time>7</g:min_transit_time><g:max_transit_time>10</g:max_transit_time></g:shipping>
    <g:shipping><g:country>${c}</g:country><g:service>Express</g:service><g:price>${c==='AU'?'49.95':c==='AE'?'39.95':'39.95'} ${cur}</g:price><g:min_handling_time>3</g:min_handling_time><g:max_handling_time>5</g:max_handling_time><g:min_transit_time>3</g:min_transit_time><g:max_transit_time>5</g:max_transit_time></g:shipping>`).join('');
}

async function fetchAllProducts() {
  const all=[]; let cursor=null, hasNext=true;
  while(hasNext) {
    const v={first:250}; if(cursor) v.after=cursor;
    const r=await fetch(SHOPIFY_STOREFRONT_URL,{method:'POST',headers:{'Content-Type':'application/json','X-Shopify-Storefront-Access-Token':SHOPIFY_STOREFRONT_TOKEN},body:JSON.stringify({query:ALL_PRODUCTS_QUERY,variables:v})});
    if(!r.ok) break;
    const d=await r.json(), edges=d?.data?.products?.edges||[];
    all.push(...edges.map(e=>e.node));
    hasNext=d?.data?.products?.pageInfo?.hasNextPage??false;
    cursor=d?.data?.products?.pageInfo?.endCursor??null;
  }
  return all.filter(p=>p.availableForSale!==false);
}

function productItemXml(p) {
  const link=`${SITE_URL}/product/${p.handle}`, img=p.images.edges[0]?.node.url?forceJpeg(p.images.edges[0].node.url):`${SITE_URL}/og-image.jpg`;
  const addImgs=p.images.edges.slice(1,5).map(e=>forceJpeg(e.node.url));
  const price=p.priceRange.minVariantPrice.amount, cur=p.priceRange.minVariantPrice.currencyCode;
  const comp=p.compareAtPriceRange?.maxVariantPrice?.amount, priceN=parseFloat(price), compN=comp?parseFloat(comp):0, disc=compN>priceN;
  const gpc=getGoogleProductCategory(p.productType,p.title), sizes=getSizes(p), gender=getGender(p.productType,p.title);
  const col=p.options?.find(o=>/color/i.test(o.name))?.values?.[0]||'', mat=p.options?.find(o=>/fabric|material/i.test(o.name))?.values?.[0]||'';
  const sku=(p.variants.edges[0]?.node?.sku||p.id.split('/').pop()||'').replace(/\s+/g,'-').replace(/[^a-zA-Z0-9_-]/g,'');
  const pat=p.tags?.find(t=>/embroider|work|print|woven/i.test(t))||'';
  const desc=(p.description||`Shop ${p.title} at LuxeMia. Premium Indian ethnic wear with worldwide shipping.`).slice(0,5000);
  const pt=p.productType||'Ethnic Wear';
  const entries=[];
  if(sizes.length>0) {
    for(const size of sizes) {
      const ss=size.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,''), iid=sku?`${sku}-${ss}`:`${p.handle}-${ss}`;
      const mv=p.variants.edges.find(v=>v.node.selectedOptions?.some(o=>(/size|bust size/i.test(o.name))&&o.value===size));
      const vp=mv?.node?.price?.amount||price, vc=mv?.node?.compareAtPrice?.amount||comp, vd=vc?parseFloat(vc)>parseFloat(vp):false;
      // GMC CRITICAL: g:price = original (higher) price, g:sale_price = discounted (lower) price
      const dp=vd?vc:vp, sp=vd?vp:'';
      entries.push(`<item><g:id>${escapeXml(iid)}</g:id><g:item_group_id>${escapeXml(p.handle)}</g:item_group_id><g:title>${escapeXml(p.title)}</g:title><g:description>${escapeXml(desc)}</g:description><g:link>${escapeXml(link)}</g:link><g:image_link>${escapeXml(img)}</g:image_link>${addImgs.map(i=>`<g:additional_image_link>${escapeXml(i)}</g:additional_image_link>`).join('')}<g:availability>in_stock</g:availability><g:price>${dp} ${cur}</g:price>${sp?`<g:sale_price>${sp} ${cur}</g:sale_price>`:''}<g:condition>new</g:condition><g:brand>${escapeXml(p.vendor||'LuxeMia')}</g:brand><g:google_product_category>${gpc}</g:google_product_category><g:product_type>${escapeXml(pt)}</g:product_type><g:gender>${gender}</g:gender><g:age_group>adult</g:age_group>${col?`<g:color>${escapeXml(col)}</g:color>`:''}${mat?`<g:material>${escapeXml(mat)}</g:material>`:''}${pat?`<g:pattern>${escapeXml(pat)}</g:pattern>`:''}<g:size>${escapeXml(size)}</g:size><g:size_type>regular</g:size_type><g:size_system>US</g:size_system><g:identifier_exists>no</g:identifier_exists><g:custom_label_0>${escapeXml(pt)}</g:custom_label_0>${shippingXml(cur)}<g:tax><g:country>US</g:country><g:rate>0</g:rate><g:tax_ship>no</g:tax_ship></g:tax></item>`);
    }
  } else {
    // GMC CRITICAL: g:price = original (higher) price, g:sale_price = discounted (lower) price
    const dp2=disc?comp:price, sp2=disc?price:'';
    entries.push(`<item><g:id>${escapeXml(sku||p.handle)}</g:id><g:title>${escapeXml(p.title)}</g:title><g:description>${escapeXml(desc)}</g:description><g:link>${escapeXml(link)}</g:link><g:image_link>${escapeXml(img)}</g:image_link>${addImgs.map(i=>`<g:additional_image_link>${escapeXml(i)}</g:additional_image_link>`).join('')}<g:availability>in_stock</g:availability><g:price>${dp2} ${cur}</g:price>${sp2?`<g:sale_price>${sp2} ${cur}</g:sale_price>`:''}<g:condition>new</g:condition><g:brand>${escapeXml(p.vendor||'LuxeMia')}</g:brand><g:google_product_category>${gpc}</g:google_product_category><g:product_type>${escapeXml(pt)}</g:product_type><g:gender>${gender}</g:gender><g:age_group>adult</g:age_group>${col?`<g:color>${escapeXml(col)}</g:color>`:''}${mat?`<g:material>${escapeXml(mat)}</g:material>`:''}${pat?`<g:pattern>${escapeXml(pat)}</g:pattern>`:''}<g:identifier_exists>no</g:identifier_exists><g:custom_label_0>${escapeXml(pt)}</g:custom_label_0>${shippingXml(cur)}<g:tax><g:country>US</g:country><g:rate>0</g:rate><g:tax_ship>no</g:tax_ship></g:tax></item>`);
  }
  return entries.join('\n');
}

export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin','*');
  res.setHeader('Access-Control-Allow-Methods','GET,HEAD,OPTIONS');
  res.setHeader('Content-Type','application/xml; charset=utf-8');
  res.setHeader('Cache-Control','public,s-maxage=3600,stale-while-revalidate=86400');
  if(req.method==='OPTIONS') { res.status(204).end(); return; }
  if(req.method!=='GET'&&req.method!=='HEAD') { res.status(405).send('<?xml version="1.0"?><rss version="2.0"><channel><title>Method Not Allowed</title></channel></rss>'); return; }
  try {
    const products=await fetchAllProducts();
    const items=products.map(p=>productItemXml(p)).join('\n');
    res.status(200).send(`<?xml version="1.0" encoding="UTF-8"?>\n<rss version="2.0" xmlns:g="http://base.google.com/ns/1.0">\n<channel>\n  <title>LuxeMia - Indian Ethnic Wear</title>\n  <link>${SITE_URL}</link>\n  <description>Shop quality Indian ethnic wear at LuxeMia. Flat rate shipping $25, free on orders over $350.</description>\n  <last_build_date>${new Date().toISOString()}</last_build_date>\n${items}\n</channel>\n</rss>`);
  } catch(e) {
    console.error('Merchant feed error:',e);
    res.status(500).send('<?xml version="1.0"?><rss version="2.0"><channel><title>Error</title><description>Temporary error. Try /merchant-feed.xml instead.</description></channel></rss>');
  }
}
