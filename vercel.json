{
  "framework": "vite",
  "buildCommand": "npm run build && node scripts/generate-merchant-feed.cjs",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/collections/wedding-sarees", "destination": "/sarees", "permanent": true },
    { "source": "/collections/bridal-lehengas", "destination": "/lehengas", "permanent": true },
    { "source": "/collections/reception-outfits", "destination": "/collections", "permanent": true },
    { "source": "/collections/festive-wear", "destination": "/collections", "permanent": true },
    { "source": "/collections/sarees", "destination": "/sarees", "permanent": true },
    { "source": "/collections/salwar-kameez", "destination": "/suits", "permanent": true },
    { "source": "/collections/suits", "destination": "/suits", "permanent": true },
    { "source": "/collections/menswear", "destination": "/menswear", "permanent": true },
    { "source": "/collections/lehengas", "destination": "/lehengas", "permanent": true },
    { "source": "/collections/indo-western", "destination": "/indowestern", "permanent": true },
    { "source": "/collections/bridesmaid-dresses", "destination": "/sarees", "permanent": true },
    { "source": "/collections/groomsman-outfits", "destination": "/menswear", "permanent": true },
    { "source": "/our-story", "destination": "/brand-story", "permanent": true },
    { "source": "/lookbook", "destination": "/collections", "permanent": true },
    { "source": "/jewelry", "destination": "/collections", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_prerender/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/merchant-feed.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/merchant-feed.tsv",
      "headers": [
        { "key": "Content-Type", "value": "text/tab-separated-values; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/_prerender/(.*)", "destination": "/_prerender/$1" },
    { "source": "/google4e3f332d00afc8ba.html", "destination": "/google4e3f332d00afc8ba.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
