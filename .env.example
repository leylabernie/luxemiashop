# Shopify Storefront API
# Get these from Shopify Admin > Apps > Develop apps > [Your App] > API credentials
# IMPORTANT: Never commit the actual token to the repository.
# After deploying, add these as environment variables in Vercel Dashboard > Settings > Environment Variables.

# Client-side token (VITE_ prefix required for Vite to expose it)
VITE_SHOPIFY_STOREFRONT_TOKEN=your_shopify_storefront_token_here

# Server-side token (used by middleware.ts and build scripts)
SHOPIFY_STOREFRONT_TOKEN=your_shopify_storefront_token_here
